<?xml version="1.0" encoding="utf-8"?>
<!--
  Primeiro plano do ícone adaptativo: um cadeado no accent azul da UI (#4C8DFF),
  com leve gradiente. Vetorial puro (sem PNG, sem dependências). O desenho fica
  dentro da "safe zone" central (72dp) do viewport 108dp para não ser cortado
  pelas máscaras do launcher.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Arco (shackle) do cadeado, aberto na base, encaixando no corpo. -->
    <path
        android:strokeColor="#4C8DFF"
        android:strokeWidth="7.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M42,52 L42,44 A12,12 0 0 1 66,44 L66,52" />

    <!-- Corpo do cadeado, com gradiente azul. -->
    <path android:pathData="M34,50 L74,50 A6,6 0 0 1 80,56 L80,80 A6,6 0 0 1 74,86 L34,86 A6,6 0 0 1 28,80 L28,56 A6,6 0 0 1 34,50 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28" android:startY="50"
                android:endX="80" android:endY="86">
                <item android:offset="0.0" android:color="#6BA5FF" />
                <item android:offset="1.0" android:color="#3C7DF0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Buraco da fechadura, na cor do fundo. -->
    <path
        android:fillColor="#121317"
        android:pathData="M54,60 m-5,0 a5,5 0 1 0 10,0 a5,5 0 1 0 -10,0 Z" />
    <path
        android:fillColor="#121317"
        android:pathData="M51.5,64 L56.5,64 L58,78 L50,78 Z" />
</vector>
