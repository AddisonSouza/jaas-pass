<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Offline absoluto (design constraint 2): NENHUMA permissão é declarada.
      Em especial, SEM android.permission.INTERNET.
    -->

    <application
        android:name=".App"
        android:allowBackup="false"
        android:label="jaas-pass"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">

        <activity
            android:name=".ui.UnlockActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.ListActivity" android:exported="false" />
        <activity android:name=".ui.DetailActivity" android:exported="false" />
        <activity android:name=".ui.AddEditActivity" android:exported="false" />
    </application>

</manifest>
